PORT=5000
CLIENT_ORIGINS=http://localhost,capacitor://localhost,ionic://localhost,http://localhost:5000,https://ten-mien-cua-ban.com
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
SEED_ADMIN_PASSWORD=replace-admin-demo-password
SEED_RESCUE_PASSWORD=replace-rescue-demo-password
SEED_CITIZEN_PASSWORD=replace-citizen-demo-password

# Local PostgreSQL through pgAdmin/PostgreSQL.
# Use a new database for this standalone RescueVN app, do not point to the old Ha Tinh web database.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rescuevn_app?schema=public
APP_PROJECT_CODE=RESCUEVN_APP

# Use PGSSL=true only on hosting providers that require SSL.
PGSSL=false
