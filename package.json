{
  "name": "rescuevn-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node scripts/start-server.js",
    "server": "node server.js",
    "build": "prisma generate",
    "db:create": "node scripts/create-prisma-database.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/seed-prisma.js",
    "db:seed-if-empty": "node scripts/seed-if-empty.js",
    "db:setup": "npm run db:create && npm run db:deploy && npm run db:generate && npm run db:seed",
    "db:reset-local": "node scripts/reset-prisma-database.js && npm run db:deploy && npm run db:generate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
